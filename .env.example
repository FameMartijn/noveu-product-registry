# Product Registry Service Configuration
NODE_ENV=development
PORT=4013
SERVICE_NAME=product-registry

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noveu_platform
DB_USER=noveu_user
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Service-to-Service Authentication
SERVICE_API_KEY=your-service-api-key-here

# GitHub Integration (for release downloads)
GITHUB_PAT=ghp_your_github_personal_access_token_here

# License Service Integration
LICENSE_SERVICE_URL=http://localhost:4005

# Database Advanced Settings (optional)
DB_SCHEMA=product_registry
DB_SSL=false
DB_SYNCHRONIZE=
DB_LOGGING=
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT_MS=2000
DB_IDLE_TIMEOUT_MS=30000
DB_MAX_QUERY_TIME=5000
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=3000
DB_RUN_MIGRATIONS=false

# Rate Limiting (optional)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
